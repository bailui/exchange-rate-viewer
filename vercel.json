{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/exchange-rate", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/exchange-rate", "destination": "/exchange-rate/index.html" },
    { "source": "/calculator", "destination": "/calculator/index.html" },
    { "source": "/trends", "destination": "/trends/index.html" },
    { "source": "/alerts", "destination": "/alerts/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
